#!/usr/bin/env bash
# Thin launcher for the cleanup CLI. Uses the cleanup folder's venv if present.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON="${HERE}/.venv/bin/python"
if [[ ! -x "${PYTHON}" ]]; then
  PYTHON="$(command -v python3)"
fi
exec "${PYTHON}" -m macparakeet_cleanup.cli "$@"
